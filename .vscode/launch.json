{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug steam-haptics-player (gdb)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}\\steam-haptics-player.exe",
      "args": [
        "-s"
      ],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "C:\\msys64\\ucrt64\\bin\\gdb.exe",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}